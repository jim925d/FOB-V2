DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/skillbridge
REDIS_URL=redis://localhost:6379/0
GEOCODING_API_KEY=your_opencage_api_key_here
GEOCODING_PROVIDER=opencage
SCRAPE_INTERVAL_HOURS=168
API_SECRET_KEY=change-me-in-production
SCRAPE_DELAY_MIN=2
SCRAPE_DELAY_MAX=5
SCRAPE_BASE_URL=https://skillbridge.osd.mil/locations.htm
LOG_LEVEL=INFO
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# CORS — add your Vercel/production frontend URL when deploying (JSON array)
# Example production: ["https://your-app.vercel.app","https://thefob.com"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://thefob.com"]

# Veteran events scrape (Employment & Networking Local Search) — Google Custom Search
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Supabase (optional): JWT verification for protected endpoints (e.g. ERG submit)
# Get JWT Secret from Supabase Dashboard → Settings → API → JWT Secret. Never expose service_role key.
SUPABASE_URL=
SUPABASE_JWT_SECRET=
